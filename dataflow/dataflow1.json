{
	"name": "dataflow1",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_nestedJson_SRC",
						"type": "DatasetReference"
					},
					"name": "nestedjsonsrc"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_SNK_SQL",
						"type": "DatasetReference"
					},
					"name": "jsonnestedtoSql"
				}
			],
			"transformations": [
				{
					"name": "flatten1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          class as string,",
				"          school_name as string,",
				"          students as (grade as (chemistry as short, math as short, physics as short), id as string, name as string)[]",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     documentForm: 'arrayOfDocuments') ~> nestedjsonsrc",
				"nestedjsonsrc foldDown(unroll(students, students),",
				"     mapColumn(",
				"          class,",
				"          school_name,",
				"          students",
				"     ),",
				"     skipDuplicateMapInputs: false,",
				"     skipDuplicateMapOutputs: false) ~> flatten1",
				"flatten1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          School_Name as string,",
				"          Class as string,",
				"          Student_ID as string,",
				"          Student_Name as string,",
				"          Student_Math_grade as integer,",
				"          Student_Physics_grade as integer,",
				"          Student_Chemistry_grade as integer",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          School_Name = school_name,",
				"          Class = class,",
				"          Student_ID = students.id,",
				"          Student_Name = students.name,",
				"          Student_Math_grade = students.grade.math,",
				"          Student_Physics_grade = students.grade.physics,",
				"          Student_Chemistry_grade = students.grade.chemistry",
				"     )) ~> jsonnestedtoSql"
			]
		}
	}
}
{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "dflahari"
		},
		"Lnk_ADLS_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'Lnk_ADLS'"
		},
		"Lnk_onprem_ir_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'Lnk_onprem_ir'"
		},
		"Lnk_ADLS_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://datalakelahari.dfs.core.windows.net/"
		},
		"Lnk_onprem_ir_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "LAHARI"
		},
		"Lnk_onprem_ir_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "Lahari"
		},
		"Lnk_onprem_ir_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "dedeepya1"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "dflahari_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"Lnk_ADLS_accountKey": {
						"value": "[parameters('Lnk_ADLS_accountKey')]"
					},
					"Lnk_onprem_ir_password": {
						"value": "[parameters('Lnk_onprem_ir_password')]"
					},
					"Lnk_ADLS_properties_typeProperties_url": {
						"value": "[parameters('Lnk_ADLS_properties_typeProperties_url')]"
					},
					"Lnk_onprem_ir_properties_typeProperties_server": {
						"value": "[parameters('Lnk_onprem_ir_properties_typeProperties_server')]"
					},
					"Lnk_onprem_ir_properties_typeProperties_database": {
						"value": "[parameters('Lnk_onprem_ir_properties_typeProperties_database')]"
					},
					"Lnk_onprem_ir_properties_typeProperties_userName": {
						"value": "[parameters('Lnk_onprem_ir_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}
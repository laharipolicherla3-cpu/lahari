				"typeProperties": {
					"server": "[parameters('Lnk_sql_properties_typeProperties_server')]",
					"database": "[parameters('Lnk_sql_properties_typeProperties_database')]",
					"encrypt": "optional",
					"trustServerCertificate": false,
					"authenticationType": "SQL",
					"userName": "[parameters('Lnk_sql_properties_typeProperties_userName')]",
					"password": {

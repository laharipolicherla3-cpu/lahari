			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "dflahari"
		},
		"Lnk_ADLS_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'Lnk_ADLS'"
		},
		"Lnk_sql_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'Lnk_sql'"
		},
		"Lnk_ADLS_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://datalakelahari.dfs.core.windows.net/"
		},
		"Lnk_sql_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "lahari-server.database.windows.net"
		},
		"Lnk_sql_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "lahari_db"
		},
		"Lnk_sql_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "lahari-admin"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
